# ─────────────────────────────────────────────────────────────────────────────
# Optional LOCAL-ONLY live-mode smoke testing.
#
# The PRODUCTION app does NOT read these. In production, configuration is shipped
# as an AES-encrypted blob (src/lib/encrypted-config.ts), generated with the
# in-app admin form (?admin=1), and unlocked at runtime via the URL hash
# (#key=YOUR_PASSWORD).
#
# These vars only let YOU run live mode locally without going through the blob.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# When set to "1", the app reads the VITE_* config below instead of requiring
# the encrypted blob + URL key. NEVER set this in a committed/deployed build.
VITE_LOCAL_LIVE=0

# Firebase (project swot-1a7f2)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=swot-1a7f2.firebaseapp.com
VITE_FB_DATABASE_URL=https://swot-1a7f2-default-rtdb.europe-west1.firebasedatabase.app
VITE_FB_PROJECT_ID=swot-1a7f2
VITE_FB_STORAGE_BUCKET=swot-1a7f2.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=295271212780
VITE_FB_APP_ID=

# OpenRouter
VITE_OPENROUTER_KEY=
VITE_OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Mission/session id (Firebase path namespace)
VITE_SESSION_ID=mission-1946
